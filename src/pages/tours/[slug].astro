---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const tours = await getCollection('tours');
  return tours.map((tour) => ({
    params: { slug: tour.data.slug },
    props: { tour },
  }));
};

const { tour } = Astro.props;
const t = tour.data;

const pageTitle = `${t.title} | Active Oahu Tours`;
const pageDescription = t.seo?.description || `Book the ${t.title} with Active Oahu Tours. ${t.duration} • ${t.difficulty} difficulty • Starting at $${t.price}/person.`;

const tourSchema = {
  '@context': 'https://schema.org',
  '@type': 'TouristTrip',
  name: t.title,
  description: pageDescription,
  touristType: 'Adults, Families',
  provider: {
    '@type': 'LocalBusiness',
    name: 'Active Oahu Tours',
    url: 'https://activeoahutours.com',
  },
  offers: {
    '@type': 'Offer',
    price: t.price,
    priceCurrency: 'USD',
    availability: 'https://schema.org/InStock',
  },
};
---

<BaseLayout
  title={t.seo?.title || pageTitle}
  description={pageDescription}
  image={t.image}
  schema={tourSchema}
>
  <!-- Tour Hero -->
  <section class="relative overflow-hidden min-h-[40vh] lg:min-h-[50vh] flex items-center">
    <div class="absolute inset-0 z-0">
      <img
        src={t.image}
        alt={t.imageAlt}
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-navy/70 via-navy/50 to-navy/80" />
    </div>
    <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
      <div class="max-w-2xl">
        <span class="inline-block px-3 py-1 bg-gold/90 text-navy text-sm font-bold uppercase rounded-full mb-4">
          {t.category}
        </span>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-tight mb-4">
          {t.title}
        </h1>
        <p class="text-lg text-white/80 mb-6">
          {t.duration} • {t.location} • {t.difficulty} difficulty
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href={`https://fareharbor.com/embeds/book/activeoahutours/?full-items=yes`}
            class="inline-flex items-center px-8 py-3.5 bg-gold hover:bg-gold-dark text-navy font-bold text-lg rounded-xl transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5"
          >
            Book Now — ${t.price}
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Tour Details Grid -->
  <section class="py-12 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12">
        <!-- Main Content -->
        <div class="lg:col-span-2">
          <div class="prose prose-lg max-w-none">
            <slot />
          </div>

          <!-- FareHarbor Booking Embed -->
          <div class="mt-12 p-6 lg:p-8 bg-sand/50 rounded-2xl border border-sand">
            <h2 class="text-2xl font-bold text-navy mb-4">Ready to Book?</h2>
            <p class="text-navy/70 mb-6">Select your date and reserve your spot. Tours fill up fast — especially during peak season.</p>
            <div id="fareharbor-lightframe" class="min-h-[600px]">
              <p class="text-center text-navy/50 py-12">Loading booking calendar...</p>
            </div>
            <script src="https://fareharbor.com/embeds/api/v1/?autolightframe=yes"></script>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="space-y-6">
          <!-- Quick Facts -->
          <div class="bg-navy text-white rounded-2xl p-6">
            <h3 class="text-lg font-bold text-gold mb-4">Quick Facts</h3>
            <dl class="space-y-4">
              <div>
                <dt class="text-xs uppercase tracking-wider text-white/50">Duration</dt>
                <dd class="font-semibold">{t.duration}</dd>
              </div>
              <div>
                <dt class="text-xs uppercase tracking-wider text-white/50">Difficulty</dt>
                <dd class="font-semibold capitalize">{t.difficulty}</dd>
              </div>
              <div>
                <dt class="text-xs uppercase tracking-wider text-white/50">Location</dt>
                <dd class="font-semibold">{t.location}</dd>
              </div>
              <div>
                <dt class="text-xs uppercase tracking-wider text-white/50">Price</dt>
                <dd class="font-semibold text-xl text-gold">${t.price} <span class="text-sm font-normal text-white/60">{t.priceLabel}</span></dd>
              </div>
              <div>
                <dt class="text-xs uppercase tracking-wider text-white/50">Group Size</dt>
                <dd class="font-semibold">{t.minGuests}–{t.maxGuests} guests</dd>
              </div>
            </dl>
          </div>

          <!-- Highlights -->
          {t.highlights.length > 0 && (
            <div class="bg-white rounded-2xl border border-sand p-6">
              <h3 class="text-lg font-bold text-navy mb-4">Highlights</h3>
              <ul class="space-y-2">
                {t.highlights.map((h) => (
                  <li class="flex items-start gap-2 text-sm text-navy/70">
                    <svg class="w-5 h-5 text-gold shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                    {h}
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- What's Included -->
          {t.includes.length > 0 && (
            <div class="bg-white rounded-2xl border border-sand p-6">
              <h3 class="text-lg font-bold text-navy mb-4">What's Included</h3>
              <ul class="space-y-2">
                {t.includes.map((item) => (
                  <li class="flex items-start gap-2 text-sm text-navy/70">
                    <svg class="w-5 h-5 text-ocean shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- What to Bring -->
          {t.whatToBring.length > 0 && (
            <div class="bg-cream rounded-2xl p-6">
              <h3 class="text-lg font-bold text-navy mb-4">What to Bring</h3>
              <ul class="space-y-2">
                {t.whatToBring.map((item) => (
                  <li class="flex items-start gap-2 text-sm text-navy/70">
                    <span class="text-gold font-bold shrink-0">→</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          )}
        </aside>
      </div>
    </div>
  </section>

  <!-- Tour FAQ -->
  {t.faqs.length > 0 && (
    <section id="faq" class="py-12 lg:py-20 bg-sand/50">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl lg:text-3xl font-bold text-navy text-center mb-10">Frequently Asked Questions</h2>
        <dl class="space-y-4">
          {t.faqs.map((faq, i) => (
            <div class="bg-white rounded-xl p-5 lg:p-6 shadow-sm border border-sand">
              <dt>
                <button
                  class="flex w-full items-center justify-between text-left text-navy font-semibold hover:text-ocean transition-colors"
                  aria-expanded="false"
                  data-faq-trigger={i}
                >
                  <span class="pr-4">{faq.question}</span>
                  <svg class="w-5 h-5 shrink-0 text-ocean transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </button>
              </dt>
              <dd class="mt-3 text-navy/70 text-sm leading-relaxed hidden" data-faq-answer={i}>
                {faq.answer}
              </dd>
            </div>
          ))}
        </dl>
      </div>
      <script>
        document.querySelectorAll('[data-faq-trigger]').forEach((btn) => {
          btn.addEventListener('click', () => {
            const idx = (btn as HTMLElement).dataset.faqTrigger;
            const answer = document.querySelector(`[data-faq-answer="${idx}"]`);
            const icon = btn.querySelector('svg');
            answer?.classList.toggle('hidden');
            icon?.classList.toggle('rotate-180');
            btn.setAttribute('aria-expanded', answer?.classList.contains('hidden') ? 'false' : 'true');
          });
        });
      </script>
    </section>
  )}

  <!-- Bottom Booking CTA -->
  <section class="py-12 lg:py-20 bg-ocean text-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl lg:text-3xl font-bold mb-4">Ready to Experience {t.title}?</h2>
      <p class="text-lg text-white/80 mb-8">
        Reserve your spot today. Limited availability — book now to secure your date.
      </p>
      <a
        href={`https://fareharbor.com/embeds/book/activeoahutours/?full-items=yes`}
        class="inline-flex items-center px-10 py-4 bg-gold hover:bg-gold-dark text-navy font-bold text-lg rounded-xl transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5"
      >
        Book Now — ${t.price}
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
        </svg>
      </a>
      <p class="mt-4 text-sm text-white/60">
        Or call us at <a href="tel:+180****1234" class="underline hover:text-white">(808) 555-1234</a>
      </p>
    </div>
  </section>
</BaseLayout>
