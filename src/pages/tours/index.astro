---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TourCard from '../../components/TourCard.astro';

const tours = await getCollection('tours');
const featuredTours = tours.filter((t) => t.data.featured);
const allTours = tours;

const pageTitle = 'Oahu Kayak & E-Bike Tours | Active Oahu Tours';
const pageDescription = 'Explore Oahu\'s windward coast with guided kayak tours to the Mokulua Islands, Chinaman\'s Hat, Kaneohe Bay, and Kailua. E-bike adventures, snorkeling, and more. Book online today.';

const tourSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: tours.map((tour, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'TouristTrip',
      name: tour.data.title,
      description: tour.data.seo?.description || `${tour.data.title} — ${tour.data.duration} ${tour.data.difficulty} tour in ${tour.data.location}`,
      url: `https://activeoahutours.com/tours/${tour.data.slug}/`,
    },
  })),
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image="/images/og-tours.jpg"
  schema={tourSchema}
>
  <section class="relative overflow-hidden bg-navy py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block px-3 py-1 bg-gold/90 text-navy text-sm font-bold uppercase rounded-full mb-4">
        Our Adventures
      </span>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-4">
        Oahu Kayak & E-Bike Tours
      </h1>
      <p class="text-lg text-white/70 max-w-2xl mx-auto">
        From the iconic Mokulua Islands to the tranquil waters of Kaneohe Bay. 
        Guided and self-guided adventures for every skill level.
      </p>
    </div>
  </section>

  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {allTours.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {allTours.map((tour) => (
            <TourCard
              title={tour.data.title}
              slug={tour.data.slug}
              image={tour.data.image}
              imageAlt={tour.data.imageAlt}
              price={tour.data.price}
              priceLabel={tour.data.priceLabel}
              duration={tour.data.duration}
              difficulty={tour.data.difficulty}
              location={tour.data.location}
              highlights={tour.data.highlights}
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-navy/50 text-lg">Tour listings coming soon!</p>
        </div>
      )}
    </div>
  </section>

  <section class="py-16 lg:py-24 bg-ocean text-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl lg:text-3xl font-bold mb-4">Not Sure Which Tour Is Right for You?</h2>
      <p class="text-lg text-white/80 mb-8">
        Our guides are happy to help. Call or email us — we'll match you with the perfect adventure.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:+18085551234" class="inline-flex items-center justify-center px-8 py-4 bg-white/10 backdrop-blur-sm hover:bg-white/20 text-white font-bold text-lg rounded-xl border border-white/30 transition-all">
          📞 (808) 498-1894
        </a>
        <a href="mailto:aloha@activeoahutours.com" class="inline-flex items-center justify-center px-8 py-4 bg-gold hover:bg-gold-dark text-navy font-bold text-lg rounded-xl transition-all shadow-lg">
          ✉️ Email Us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
