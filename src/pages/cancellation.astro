---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = 'Cancellation Policy | Active Oahu Tours';
const pageDescription = 'Our cancellation policy: free cancellation up to 24 hours before your tour. Weather-related cancellations are always free. Learn about our flexible booking terms for kayak, e-bike, and rental reservations.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image="/images/og-cancellation.jpg"
>
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="inline-block px-3 py-1 bg-ocean/10 text-ocean text-sm font-bold uppercase rounded-full mb-4">
        Booking Info
      </span>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-navy mb-6">
        Cancellation Policy
      </h1>
      <p class="text-lg text-navy/60 mb-10">
        We know plans can change. Here's everything you need to know about cancelling or rescheduling your Active Oahu Tours adventure.
      </p>

      <div class="prose prose-lg max-w-none text-navy/70">
        <div class="bg-green-50 border border-green-200 rounded-2xl p-6 mb-8">
          <h2 class="text-green-800 text-xl !mt-0 !mb-2">✅ Free Cancellation Window</h2>
          <p class="text-green-700 !mt-0">
            Cancel up to <strong>24 hours before</strong> your scheduled tour or rental start time for a <strong>full refund</strong>. No questions asked.
          </p>
        </div>

        <h2 class="text-navy">Late Cancellations (Within 24 Hours)</h2>
        <p>
          Cancellations made <strong>less than 24 hours</strong> before your scheduled start time are subject to a <strong>50% cancellation fee</strong>. 
          We hold your spot and turn away other guests — late cancellations help us cover guide and equipment costs.
        </p>

        <h2 class="text-navy">No-Shows</h2>
        <p>
          If you <strong>do not show up</strong> for your scheduled tour or rental pickup and haven't contacted us, 
          you will be charged the <strong>full booking amount</strong>. Please call or email us if you're running late — 
          we'll do our best to accommodate you on a later departure if space allows.
        </p>

        <h2 class="text-navy">Weather-Related Cancellations</h2>
        <p>
          <strong>Weather cancellations are always 100% free.</strong> Safety is our top priority. If we determine that 
          conditions are unsafe (high winds, lightning, dangerous surf), we will:
        </p>
        <ul>
          <li>Contact you as early as possible — usually the morning of your tour</li>
          <li>Offer to reschedule for another day or time</li>
          <li>Issue a full refund if rescheduling isn't possible</li>
        </ul>
        <p>
          <em>Note: Light rain or overcast skies are normal in Hawaii and typically don't affect tours. 
          We only cancel for conditions that pose a safety risk.</em>
        </p>

        <div class="bg-blue-50 border border-blue-200 rounded-2xl p-6 my-8">
          <h2 class="text-blue-800 text-xl !mt-0 !mb-2">🔄 Rescheduling</h2>
          <p class="text-blue-700 !mt-0">
            You may reschedule your tour or rental <strong>up to 24 hours in advance</strong> at no additional cost, 
            subject to availability. Contact us via phone or email to change your date or time.
          </p>
        </div>

        <h2 class="text-navy">Group Bookings (6+ Guests)</h2>
        <p>
          Group bookings of 6 or more guests require <strong>48 hours notice</strong> for free cancellation or rescheduling. 
          Late cancellations for groups are subject to a 50% fee; no-shows are charged in full.
        </p>

        <h2 class="text-navy">Multi-Day Rentals</h2>
        <p>
          Multi-day equipment rentals (kayaks, SUPs, beach gear) follow the same 24-hour cancellation policy. 
          If you return equipment early, we'll refund unused full days (24-hour increments) minus a small restocking fee.
        </p>

        <h2 class="text-navy">How to Cancel or Reschedule</h2>
        <p>Contact us through any of these methods:</p>
        <ul>
          <li><strong>Phone:</strong> <a href="tel:+18085551234" class="text-ocean hover:underline">(808) 555-1234</a></li>
          <li><strong>Email:</strong> <a href="mailto:aloha@activeoahutours.com" class="text-ocean hover:underline">aloha@activeoahutours.com</a></li>
          <li><strong>In person:</strong> Visit our Kailua storefront at 130 Kailua Road</li>
        </ul>
        <p>
          Please include your <strong>booking confirmation number</strong> and the <strong>name</strong> the reservation was made under.
        </p>

        <h2 class="text-navy">Refund Processing</h2>
        <p>
          Refunds are processed within <strong>3-5 business days</strong> to the original payment method. 
          You'll receive an email confirmation once your refund has been initiated.
        </p>

        <div class="bg-gold/10 border border-gold/30 rounded-2xl p-6 mt-8">
          <h2 class="text-navy text-xl !mt-0 !mb-2">📞 Questions?</h2>
          <p class="!mt-0">
            We're happy to discuss our policies or your specific situation. 
            <a href="tel:+18085551234" class="text-ocean font-semibold hover:underline">Give us a call</a> or 
            <a href="mailto:aloha@activeoahutours.com" class="text-ocean font-semibold hover:underline">send us an email</a> 
            — we're real people who want you to have an amazing Oahu experience.
          </p>
        </div>
      </div>

      <div class="mt-12 text-center">
        <a
          href="/#book"
          class="inline-flex items-center px-8 py-4 bg-ocean hover:bg-ocean-light text-white font-bold text-lg rounded-xl transition-all shadow-lg"
        >
          Back to Booking
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
