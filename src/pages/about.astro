---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';

const pageTitle = 'About Active Oahu Tours | Kailua Kayak & E-Bike Guides';
const pageDescription = 'Meet the local guides behind Active Oahu Tours — Kailua\'s premier kayak and e-bike adventure company. CPR certified, Coast Guard compliant, and TripAdvisor award-winning.';

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Active Oahu Tours',
  url: 'https://activeoahutours.com',
  description: pageDescription,
  foundingDate: '2018',
  founders: [
    { '@type': 'Person', name: 'Kai Nakamura' },
    { '@type': 'Person', name: 'Leilani Kealoha' },
  ],
  address: {
    '@type': 'PostalAddress',
    streetAddress: '130 Kailua Road',
    addressLocality: 'Kailua',
    addressRegion: 'HI',
    postalCode: '96734',
    addressCountry: 'US',
  },
  telephone: '(808) 498-1894',
  email: 'aloha@activeoahutours.com',
  award: 'TripAdvisor Travelers\' Choice 2024',
  sameAs: [
    'https://www.instagram.com/activeoahutours',
    'https://www.facebook.com/activeoahutours',
    'https://www.tripadvisor.com/activeoahutours',
  ],
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image="/images/about-team.jpg"
  schema={organizationSchema}
>
  <!-- Hero -->
  <HeroSection
    headline="Kailua Born. Ocean Raised."
    subheadline="We're a small team of Oahu locals who turned our passion for the ocean into the island's most personal adventure experiences. Every tour is led by guides who grew up on these waters."
    image="/images/about-hero.jpg"
    imageAlt="Active Oahu Tours guides standing on Kailua Beach with kayaks, Ko'olau mountains in the background"
    ctaText="Meet Our Tours"
    ctaLink="/#tours"
    secondaryCtaText="Read Reviews"
    secondaryCtaLink="/reviews"
  />

  <!-- Company Story -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-block px-3 py-1 bg-ocean/10 text-ocean text-sm font-semibold uppercase tracking-wider rounded-full mb-4">Our Story</span>
        <h2 class="text-3xl lg:text-4xl font-bold text-navy mb-6">From Two Kayaks to Oahu's Top-Rated Tour Company</h2>
      </div>

      <div class="prose prose-lg max-w-none text-navy/70">
        <p class="text-xl text-navy/90 leading-relaxed">
          Active Oahu Tours started in 2018 with two used kayaks, a beat-up pickup truck, and a simple belief: <strong class="text-navy">the best way to experience Hawaii is on the water, with someone who calls it home.</strong>
        </p>

        <p>
          Founders Kai Nakamura and Leilani Kealoha grew up in Kailua, spending their childhood paddling to the Mokulua Islands, snorkeling the reefs, and learning the rhythms of the windward coast. After years of guiding for larger tour operators, they realized something was missing: the personal touch. The local knowledge. The aloha spirit that turns a good tour into an unforgettable memory.
        </p>

        <p>
          So they started their own company. No corporate overlords, no scripted tours, no rushed schedules. Just passionate local guides sharing the places they love with visitors who deserve more than a cookie-cutter experience.
        </p>

        <blockquote class="border-l-4 border-ocean bg-ocean/5 p-6 rounded-r-xl my-8">
          <p class="text-xl font-medium text-navy italic mb-2">
            "We don't just take you kayaking. We take you to the exact spot where the turtles feed, to the tide pool where the baby reef fish hide, to the view that makes you forget your phone exists. That's the difference a local guide makes."
          </p>
          <footer class="text-sm text-navy/50">— Kai Nakamura, Co-Founder</footer>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- Mission & Values -->
  <section class="py-16 lg:py-24 bg-sand/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-block px-3 py-1 bg-gold/10 text-gold-dark text-sm font-semibold uppercase tracking-wider rounded-full mb-4">Our Mission</span>
        <h2 class="text-3xl lg:text-4xl font-bold text-navy mb-4">What We Stand For</h2>
        <p class="text-lg text-navy/60 max-w-2xl mx-auto">
          Every paddle stroke, every pedal turn, every tour is guided by values rooted in respect — for the ocean, the culture, and our guests.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Safety -->
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-sand">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-ocean/10 mb-5">
            <svg class="w-7 h-7 text-ocean" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-navy mb-3">Safety Without Compromise</h3>
          <p class="text-navy/70 text-sm leading-relaxed">
            Every guide holds current CPR, First Aid, and Water Safety certifications. We comply with all U.S. Coast Guard regulations, maintain top-quality equipment with regular inspections, and monitor weather conditions in real time. Safety isn't a checkbox — it's the foundation everything else is built on.
          </p>
        </div>

        <!-- Authenticity -->
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-sand">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-ocean/10 mb-5">
            <svg class="w-7 h-7 text-ocean" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-navy mb-3">Authentically Local</h3>
          <p class="text-navy/70 text-sm leading-relaxed">
            We're not transplants who moved here last year. Our guides were born and raised on Oahu. We know which mornings the water will be glassy, where the turtles congregate, and the history behind every beach, bay, and mountain you'll see. When you tour with us, you experience Hawaii through local eyes — not a guidebook script.
          </p>
        </div>

        <!-- Stewardship -->
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-sand">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-ocean/10 mb-5">
            <svg class="w-7 h-7 text-ocean" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-navy mb-3">Ocean Stewardship</h3>
          <p class="text-navy/70 text-sm leading-relaxed">
            The ocean has given us everything. We give back through reef-safe practices, Leave No Trace principles on every tour, and active participation in local beach cleanups and conservation efforts. We educate every guest about Hawaii's fragile marine ecosystem and how to protect it.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Certifications & Awards -->
  <section class="py-16 lg:py-24 bg-navy text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold mb-4">Certifications & Recognition</h2>
        <p class="text-lg text-white/70 max-w-2xl mx-auto">
          We take our responsibilities seriously. Here's what backs up every tour we run.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="text-center p-8 rounded-2xl bg-navy-light/50 border border-white/10">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gold/20 mb-4">
            <svg class="w-8 h-8 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <h3 class="font-bold text-lg mb-2">CPR Certified</h3>
          <p class="text-white/60 text-sm">All guides maintain current CPR & First Aid certifications through the American Red Cross.</p>
        </div>

        <div class="text-center p-8 rounded-2xl bg-navy-light/50 border border-white/10">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gold/20 mb-4">
            <svg class="w-8 h-8 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/>
            </svg>
          </div>
          <h3 class="font-bold text-lg mb-2">Coast Guard Compliant</h3>
          <p class="text-white/60 text-sm">All vessels, safety gear, and operating procedures comply with U.S. Coast Guard regulations.</p>
        </div>

        <div class="text-center p-8 rounded-2xl bg-navy-light/50 border border-white/10">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gold/20 mb-4">
            <svg class="w-8 h-8 text-gold" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          </div>
          <h3 class="font-bold text-lg mb-2">TripAdvisor Award</h3>
          <p class="text-white/60 text-sm">Proud recipient of the TripAdvisor Travelers' Choice Award for consistently outstanding reviews.</p>
        </div>

        <div class="text-center p-8 rounded-2xl bg-navy-light/50 border border-white/10">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gold/20 mb-4">
            <svg class="w-8 h-8 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
            </svg>
          </div>
          <h3 class="font-bold text-lg mb-2">Locally Owned</h3>
          <p class="text-white/60 text-sm">100% locally owned and operated. Every dollar stays in Hawaii, supporting our community and local economy.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-block px-3 py-1 bg-gold/10 text-gold-dark text-sm font-semibold uppercase tracking-wider rounded-full mb-4">Meet Your Guides</span>
        <h2 class="text-3xl lg:text-4xl font-bold text-navy mb-4">The People Behind the Paddles</h2>
        <p class="text-lg text-navy/60 max-w-2xl mx-auto">
          Our guides aren't just employees — they're the heart of every tour. Get to know the faces you'll see on the water.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Kai -->
        <div class="bg-white rounded-2xl overflow-hidden shadow-md border border-sand group hover:shadow-xl transition-shadow">
          <div class="aspect-[4/5] bg-sand flex items-center justify-center">
            <div class="text-center p-8">
              <div class="w-24 h-24 mx-auto rounded-full bg-navy text-gold flex items-center justify-center text-3xl font-bold mb-4">KN</div>
              <p class="text-navy/40 text-sm">Photo: Kai Nakamura</p>
            </div>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-navy mb-1">Kai Nakamura</h3>
            <p class="text-ocean font-medium text-sm mb-3">Co-Founder & Lead Guide</p>
            <p class="text-navy/70 text-sm leading-relaxed mb-4">
              Born and raised in Kailua. Kai has logged over 5,000 hours on Oahu waters. CPR/First Aid certified, Coast Guard licensed, and certified marine naturalist. When he's not guiding, he's surfing or free diving the same reefs he shows guests.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="px-2.5 py-0.5 bg-ocean/10 text-ocean text-xs font-medium rounded-full">CPR/First Aid</span>
              <span class="px-2.5 py-0.5 bg-ocean/10 text-ocean text-xs font-medium rounded-full">Marine Naturalist</span>
              <span class="px-2.5 py-0.5 bg-ocean/10 text-ocean text-xs font-medium rounded-full">Paddle Instructor</span>
            </div>
          </div>
        </div>

        <!-- Leilani -->
        <div class="bg-white rounded-2xl overflow-hidden shadow-md border border-sand group hover:shadow-xl transition-shadow">
          <div class="aspect-[4/5] bg-sand flex items-center justify-center">
            <div class="text-center p-8">
              <div class="w-24 h-24 mx-auto rounded-full bg-ocean text-white flex items-center justify-center text-3xl font-bold mb-4">LK</div>
              <p class="text-navy/40 text-sm">Photo: Leilani Kealoha</p>
            </div>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-navy mb-1">Leilani Kealoha</h3>
            <p class="text-ocean font-medium text-sm mb-3">Co-Founder & Operations Manager</p>
            <p class="text-navy/70 text-sm leading-relaxed mb-4">
              Leilani's family has lived on Oahu's windward coast for five generations. She combines deep cultural knowledge with CPR certification and safety expertise. She runs operations, trains guides, and still leads tours when the conditions are perfect.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="px-2.5 py-0.5 bg-ocean/10 text-ocean text-xs font-medium rounded-full">CPR/First Aid</span>
              <span class="px-2.5 py-0.5 bg-ocean/10 text-ocean text-xs font-medium rounded-full">Cultural Guide</span>
              <span class="px-2.5 py-0.5 bg-ocean/10 text-ocean text-xs font-medium rounded-full">Operations</span>
            </div>
          </div>
        </div>

        <!-- Makoa -->
        <div class="bg-white rounded-2xl overflow-hidden shadow-md border border-sand group hover:shadow-xl transition-shadow">
          <div class="aspect-[4/5] bg-sand flex items-center justify-center">
            <div class="text-center p-8">
              <div class="w-24 h-24 mx-auto rounded-full bg-gold text-navy flex items-center justify-center text-3xl font-bold mb-4">MK</div>
              <p class="text-navy/40 text-sm">Photo: Makoa Kalama</p>
            </div>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-navy mb-1">Makoa Kalama</h3>
            <p class="text-ocean font-medium text-sm mb-3">Senior Guide & Wildlife Specialist</p>
            <p class="text-navy/70 text-sm leading-relaxed mb-4">
              Makoa studied marine biology at UH Manoa and brings science-backed wildlife knowledge to every tour. He knows the resident turtle population by identifying marks, can spot whale spouts from a mile away, and makes even the most nervous beginners feel at ease.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="px-2.5 py-0.5 bg-ocean/10 text-ocean text-xs font-medium rounded-full">CPR/First Aid</span>
              <span class="px-2.5 py-0.5 bg-ocean/10 text-ocean text-xs font-medium rounded-full">Marine Biology</span>
              <span class="px-2.5 py-0.5 bg-ocean/10 text-ocean text-xs font-medium rounded-full">Wildlife Expert</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Local Matters -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl lg:text-4xl font-bold text-navy mb-6">Why Local Guides Make All the Difference</h2>
      <div class="prose prose-lg max-w-none text-navy/70 mx-auto">
        <p class="text-lg">
          Anyone can hand you a kayak and point toward the ocean. A local guide shows you the <strong>where</strong> and the <strong>when</strong> — the hidden snorkeling spot that only works on an incoming tide, the window when the wind will be at your back for the paddle home, the reef ledge where the octopus hangs out.
        </p>
        <p>
          We grew up here. We know which beach has parking at 7 AM but not at 9 AM. We know when the Kona winds are coming before the forecast updates. We know the history of the Mokulua Islands, the significance of the fishponds in Kawainui Marsh, and why the Ko'olau mountains look the way they do. These aren't facts we memorized — they're part of who we are.
        </p>
        <p>
          <strong class="text-navy">That's the Active Oahu Tours difference.</strong> It's not just about kayaking. It's about experiencing Oahu the way we experience it. With respect, with joy, and with the kind of insider knowledge that turns a vacation activity into a lifelong memory.
        </p>
      </div>

      <div class="mt-10">
        <a
          href="/#tours"
          class="inline-flex items-center px-8 py-3.5 bg-gold hover:bg-gold-dark text-navy font-bold text-lg rounded-xl transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5"
        >
          See Our Tours
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
