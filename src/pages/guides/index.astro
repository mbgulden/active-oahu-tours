---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const guides = await getCollection('blog');
const sortedGuides = guides.sort((a, b) => {
  const da = a.data.publishedDate || new Date('2024-01-01');
  const db = b.data.publishedDate || new Date('2024-01-01');
  return db.getTime() - da.getTime();
});

const pageTitle = 'Oahu Adventure Guides | Kayaking, Snorkeling & Local Tips';
const pageDescription = 'Expert guides to kayaking, snorkeling, e-biking, hiking, and exploring Oahu like a local. Tips, itineraries, and hidden gems from the Active Oahu Tours team in Kailua.';

const categories = [
  { label: 'All Guides', value: 'all' },
  { label: 'Kayaking', value: 'kayaking' },
  { label: 'Snorkeling', value: 'snorkeling' },
  { label: 'E-Biking', value: 'ebike' },
  { label: 'Hiking', value: 'hiking' },
  { label: 'Local Tips', value: 'local-tips' },
  { label: 'Travel Planning', value: 'planning' },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image="/images/og-guides.jpg"
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-navy py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block px-3 py-1 bg-gold/90 text-navy text-sm font-bold uppercase rounded-full mb-4">
        Oahu Guides
      </span>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-4">
        Plan Your Perfect Oahu Adventure
      </h1>
      <p class="text-lg text-white/70 max-w-2xl mx-auto">
        Expert advice, local secrets, and detailed guides to kayaking, snorkeling, e-biking, 
        and exploring the windward coast. Written by the team that knows these waters best.
      </p>
    </div>
  </section>

  <!-- Guides Grid -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {sortedGuides.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {sortedGuides.map((guide) => (
            <a
              href={`/guides/${guide.data.slug}/`}
              class="group bg-white rounded-2xl border border-sand hover:border-ocean overflow-hidden shadow-sm hover:shadow-lg transition-all"
            >
              <div class="aspect-[16/9] bg-sand overflow-hidden">
                <div class="w-full h-full bg-gradient-to-br from-ocean/20 to-navy/20 flex items-center justify-center">
                  <span class="text-4xl">
                    {guide.data.pageType === 'blog' ? '📝' : '📍'}
                  </span>
                </div>
              </div>
              <div class="p-5 lg:p-6">
                <h3 class="font-bold text-navy group-hover:text-ocean transition-colors text-lg mb-2 leading-snug">
                  {guide.data.title}
                </h3>
                {guide.data.description && (
                  <p class="text-navy/60 text-sm line-clamp-2 mb-3">
                    {guide.data.description}
                  </p>
                )}
                <div class="flex items-center gap-2 text-xs text-navy/40">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  <span>Read guide</span>
                  <svg class="w-4 h-4 ml-auto group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-navy/50 text-lg">Guides coming soon! We're working on comprehensive Oahu adventure content.</p>
        </div>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 lg:py-24 bg-ocean text-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl lg:text-3xl font-bold mb-4">Ready to Stop Reading and Start Exploring?</h2>
      <p class="text-lg text-white/80 mb-8">
        Book your Oahu adventure today. Our guides are ready to show you the real Hawaii.
      </p>
      <a
        href="/#book"
        class="inline-flex items-center px-10 py-4 bg-gold hover:bg-gold-dark text-navy font-bold text-lg rounded-xl transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5"
      >
        Book Your Adventure
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
