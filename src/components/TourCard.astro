---
export interface Props {
  title: string;
  slug: string;
  image: string;
  imageAlt: string;
  price: number;
  priceLabel?: string;
  duration: string;
  difficulty: string;
  location: string;
  highlights: string[];
}

const {
  title,
  slug,
  image,
  imageAlt,
  price,
  priceLabel = 'per person',
  duration,
  difficulty,
  location,
  highlights,
} = Astro.props;

const difficultyColor = {
  easy: 'bg-green-100 text-green-800',
  moderate: 'bg-yellow-100 text-yellow-800',
  challenging: 'bg-red-100 text-red-800',
}[difficulty as string] || 'bg-gray-100 text-gray-800';

const tourUrl = `/tours/${slug}`;
---

<article class="group bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 border border-sand">
  <!-- Image -->
  <a href={tourUrl} class="block relative overflow-hidden aspect-[4/3]">
    <img
      src={image}
      alt={imageAlt}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
    />
    <div class="absolute top-3 left-3">
      <span class={`inline-block px-2.5 py-0.5 rounded-full text-xs font-semibold uppercase ${difficultyColor}`}>
        {difficulty}
      </span>
    </div>
    <div class="absolute top-3 right-3">
      <span class="inline-block px-2.5 py-0.5 bg-navy/80 text-white rounded-full text-xs font-medium">
        {duration}
      </span>
    </div>
  </a>

  <!-- Content -->
  <div class="p-5 lg:p-6">
    <h3 class="text-lg lg:text-xl font-bold text-navy mb-1 group-hover:text-ocean transition-colors">
      <a href={tourUrl}>{title}</a>
    </h3>
    <p class="text-sm text-navy/60 mb-3 flex items-center gap-1">
      <svg class="w-4 h-4 text-ocean" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
      </svg>
      {location}
    </p>

    <!-- Highlights -->
    <ul class="mb-4 space-y-1">
      {highlights.slice(0, 3).map((h) => (
        <li class="flex items-start gap-1.5 text-sm text-navy/70">
          <svg class="w-4 h-4 text-gold shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
          </svg>
          {h}
        </li>
      ))}
    </ul>

    <!-- Price & CTA -->
    <div class="flex items-center justify-between pt-4 border-t border-sand">
      <div>
        <span class="text-2xl font-bold text-ocean">${price}</span>
        <span class="text-sm text-navy/50"> {priceLabel}</span>
      </div>
      <a
        href={tourUrl}
        class="inline-flex items-center px-4 py-2 bg-ocean hover:bg-ocean-light text-white text-sm font-semibold rounded-lg transition-colors shadow-sm"
      >
        Book Now
      </a>
    </div>
  </div>
</article>
