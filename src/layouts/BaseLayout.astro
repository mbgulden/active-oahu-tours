---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  image?: string;
  schema?: any;
}

const {
  title = 'Active Oahu Tours',
  description = 'Guided kayak, e-bike, and outdoor adventures on Oahu\'s windward coast.',
  image = '/images/og-default.jpg',
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const imageURL = image.startsWith('http') ? image : new URL(image, Astro.site).href;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1a2744" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Active Oahu Tours" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Sitemap -->
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    <title>{title}</title>

    <!-- JSON-LD Structured Data Slot -->
    {Astro.props.schema && (
      <script type="application/ld+json" set:html={JSON.stringify(Astro.props.schema)} />
    )}

    <!-- FareHarbor Booking API (loads once globally) -->
    <script is:inline src="https://fareharbor.com/embeds/api/v1/?autolightframe=yes"></script>

    <!-- Google Tag Manager (manages GA4 + Ads conversions) -->
    <script is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-P55TSP');
    </script>
  </head>

  <body class="min-h-screen bg-white text-navy antialiased flex flex-col">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-P55TSP"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- Navigation -->
    <header class="sticky top-0 z-50 bg-navy shadow-lg">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16 lg:h-20">
          <!-- Logo -->
          <a href="/" class="flex items-center gap-2 text-white font-bold text-lg lg:text-xl tracking-tight">
            <span class="text-gold text-2xl">🌊</span>
            <span>Active Oahu Tours</span>
          </a>

          <!-- Desktop Nav -->
          <div class="hidden md:flex items-center gap-4">
            <a href="/tours/" class="text-white/90 hover:text-gold transition-colors text-sm font-medium uppercase tracking-wide">Tours</a>
            <a href="/rentals/" class="text-white/90 hover:text-gold transition-colors text-sm font-medium uppercase tracking-wide">Rentals</a>
            <a href="/guides/" class="text-white/90 hover:text-gold transition-colors text-sm font-medium uppercase tracking-wide">Guides</a>
            <a href="/about/" class="text-white/90 hover:text-gold transition-colors text-sm font-medium uppercase tracking-wide">About</a>
            <a href="/faq/" class="text-white/90 hover:text-gold transition-colors text-sm font-medium uppercase tracking-wide">FAQ</a>
            <a
              href="/#book"
              class="inline-flex items-center px-4 py-2 bg-ocean hover:bg-ocean-light text-white text-sm font-semibold rounded-lg transition-colors shadow-md"
            >
              Book Now
            </a>
          </div>

          <!-- Mobile Menu Toggle (placeholder for JS) -->
          <button
            id="mobile-menu-toggle"
            class="md:hidden text-white p-2 rounded-lg hover:bg-navy-light transition-colors"
            aria-label="Toggle menu"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>

        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden md:hidden pb-4">
          <div class="flex flex-col gap-3 pt-2 border-t border-white/20">
            <a href="/tours/" class="text-white/90 hover:text-gold transition-colors text-sm font-medium uppercase tracking-wide py-1">Tours</a>
            <a href="/rentals/" class="text-white/90 hover:text-gold transition-colors text-sm font-medium uppercase tracking-wide py-1">Rentals</a>
            <a href="/guides/" class="text-white/90 hover:text-gold transition-colors text-sm font-medium uppercase tracking-wide py-1">Guides</a>
            <a href="/about/" class="text-white/90 hover:text-gold transition-colors text-sm font-medium uppercase tracking-wide py-1">About</a>
            <a href="/faq/" class="text-white/90 hover:text-gold transition-colors text-sm font-medium uppercase tracking-wide py-1">FAQ</a>
            <a
              href="/#book"
              class="inline-flex items-center justify-center px-4 py-2 bg-ocean hover:bg-ocean-light text-white text-sm font-semibold rounded-lg transition-colors shadow-md"
            >
              Book Now
            </a>
          </div>
        </div>
      </nav>
    </header>

    <!-- Main Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-navy text-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
          <!-- Brand -->
          <div>
            <h3 class="text-xl font-bold mb-3">
              <span class="text-gold">🌊</span> Active Oahu Tours
            </h3>
            <p class="text-white/70 text-sm leading-relaxed">
              Guided kayak, e-bike, and outdoor adventures on Oahu's stunning windward coast. Experience the real Hawaii with local guides who call these waters home.
            </p>
          </div>

          <!-- Quick Links -->
          <div>
            <h4 class="text-sm font-semibold uppercase tracking-wider text-gold mb-4">Quick Links</h4>
            <ul class="space-y-2">
              <li><a href="/tours/" class="text-white/70 hover:text-gold text-sm transition-colors">All Tours</a></li>
              <li><a href="/rentals/" class="text-white/70 hover:text-gold text-sm transition-colors">Rentals</a></li>
              <li><a href="/guides/" class="text-white/70 hover:text-gold text-sm transition-colors">Oahu Guides</a></li>
              <li><a href="/about/" class="text-white/70 hover:text-gold text-sm transition-colors">About Us</a></li>
              <li><a href="/faq/" class="text-white/70 hover:text-gold text-sm transition-colors">FAQ</a></li>
              <li><a href="/cancellation/" class="text-white/70 hover:text-gold text-sm transition-colors">Cancellation Policy</a></li>
              <li><a href="/reviews/" class="text-white/70 hover:text-gold text-sm transition-colors">Reviews</a></li>
              <li><a href="/contact/" class="text-white/70 hover:text-gold text-sm transition-colors">Contact</a></li>
            </ul>
          </div>

          <!-- Contact -->
          <div>
            <h4 class="text-sm font-semibold uppercase tracking-wider text-gold mb-4">Contact</h4>
            <ul class="space-y-2 text-white/70 text-sm">
              <li>📍 130 Kailua Road, Kailua, HI 96734</li>
              <li>📞 <a href="tel:+18085551234" class="hover:text-gold transition-colors">(808) 555-1234</a></li>
              <li>📧 <a href="mailto:aloha@activeoahutours.com" class="hover:text-gold transition-colors">aloha@activeoahutours.com</a></li>
            </ul>
          </div>
        </div>

        <div class="mt-10 pt-6 border-t border-white/20 text-center text-white/50 text-xs">
          &copy; {new Date().getFullYear()} Active Oahu Tours. All rights reserved.
        </div>
      </div>
    </footer>

    <!-- Mobile Menu Toggle Script -->
    <script is:inline>
      (function() {
        var toggle = document.getElementById('mobile-menu-toggle');
        var menu = document.getElementById('mobile-menu');
        if (toggle && menu) {
          toggle.addEventListener('click', function() {
            if (menu.classList.contains('hidden')) {
              menu.classList.remove('hidden');
            } else {
              menu.classList.add('hidden');
            }
          });
        }
      })();
    </script>
  </body>
</html>
